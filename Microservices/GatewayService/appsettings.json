{
    "ReverseProxy": {
        "Routes": {
            "orders-route": {
                "ClusterId": "orders-cluster",
                "Match": {
                    "Path": "/orders/{**catch-all}"
                }
            },
            "notify-route": {
                "ClusterId": "notify-cluster",
                "Match": {
                    "Path": "/notify/{**catch-all}"
                }
            }
        },
        "Clusters": {
            "orders-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://order-api:8080/"
                    }
                }
            },
            "notify-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://notification-api:8080/"
                    }
                }
            }
        }
    }
}